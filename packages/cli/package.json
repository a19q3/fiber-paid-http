{
  "name": "@fiber-paid-http/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Fiber Paid HTTP gateway, bootstrap, payment, and evidence tooling.",
  "bin": {
    "fiber-paid-http": "./dist/index.js",
    "fiber-mpp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('node:fs').chmodSync('dist/index.js', 0o755)\"",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fiber-paid-http/client": "workspace:*",
    "@fiber-paid-http/core": "workspace:*",
    "@fiber-paid-http/evidence-api": "workspace:*",
    "@fiber-paid-http/evidence-web": "workspace:*",
    "@fiber-paid-http/f402-compat": "workspace:*",
    "@fiber-paid-http/fiber-method": "workspace:*",
    "@fiber-paid-http/fl402-compat": "workspace:*",
    "@fiber-paid-http/server-middleware": "workspace:*",
    "@fiber-paid-http/storage": "workspace:*",
    "commander": "^12.1.0"
  }
}
