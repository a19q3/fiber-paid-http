{
  "name": "fiber-paid-http",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "license": "MIT",
  "description": "Rust-first MPP paid HTTP gateway with a proposed Fiber payment method profile and explicit F402/F-L402 adapters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a19q3/fiber-paid-http.git"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.12.1"
  },
  "scripts": {
    "lint": "tsc -p tsconfig.json --noEmit && pnpm --filter @fiber-paid-http/evidence-web lint",
    "typecheck": "tsc -p tsconfig.json --noEmit && pnpm --filter @fiber-paid-http/evidence-web exec tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:fiber": "vitest run --config vitest.fiber.config.ts",
    "build": "pnpm -r --if-present build",
    "gate": "bash scripts/fiber_paid_http_gate.sh",
    "evidence:api": "pnpm --filter @fiber-paid-http/evidence-api start",
    "evidence:web": "pnpm --filter @fiber-paid-http/evidence-web start",
    "evidence:production-bootstrap": "node scripts/fiber_production_bootstrap_e2e.mjs",
    "battlecode:setup": "bash scripts/battlecode_setup.sh",
    "battlecode:engine-smoke": "tsx scripts/battlecode_engine_smoke.ts",
    "battlecode:demo:start": "bash scripts/battlecode_demo.sh start",
    "battlecode:demo:run": "bash scripts/battlecode_demo.sh run",
    "battlecode:demo:stop": "bash scripts/battlecode_demo.sh stop",
    "battlecode:tournament": "node scripts/battlecode_paid_http_tournament.mjs"
  },
  "dependencies": {
    "@fiber-paid-http/cli": "workspace:*",
    "@fiber-paid-http/core": "workspace:*",
    "@fiber-paid-http/fiber-method": "workspace:*",
    "@fiber-paid-http/storage": "workspace:*"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.489",
    "@types/node": "^24.0.0",
    "mppx": "0.8.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.489",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "zod": "4.3.6"
  }
}
