{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@fiber-paid-http/core": ["packages/core/src/index.ts"],
      "@fiber-paid-http/storage": ["packages/storage/src/index.ts"],
      "@fiber-paid-http/fiber-method": ["packages/fiber-method/src/index.ts"],
      "@fiber-paid-http/f402-compat": ["packages/f402-compat/src/index.ts"],
      "@fiber-paid-http/fl402-compat": ["packages/fl402-compat/src/index.ts"],
      "@fiber-paid-http/server-middleware": ["packages/server-middleware/src/index.ts"],
      "@fiber-paid-http/client": ["packages/client/src/index.ts"],
      "@fiber-paid-http/evidence-api": ["apps/evidence-api/src/index.ts"]
    }
  }
}
