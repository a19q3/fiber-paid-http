HOME=/srv/fiber-public-demo/home
RUN_FIBER_E2E=1
FIBER_MODE=local
FIBER_PAYER_RPC_URL=http://127.0.0.1:21714
FIBER_ROUTER_RPC_URL=http://127.0.0.1:21715
FIBER_PAYEE_RPC_URL=http://127.0.0.1:21716
FIBER_CURRENCY=Fibd
FIBER_ASSET=xUDT:BCODE
FIBER_XUDT_TYPE_SCRIPT={"code_hash":"0x50bd8d6680b8b9cf98b73f3c08faf8b2a21914311954118ad6609be6e78a1b95","hash_type":"data2","args":"0x32e555f3ff8e135cece1351a6a2971518392c1e30375c1e006ad0ce8eac07947"}
FIBER_E2E_AMOUNT_SHANNONS=100
FIBER_PAID_HTTP_SECRET=__GENERATE_AT_INSTALL__
FIBER_REPO=/srv/fiber-public-demo/fiber
FIBER_CKB_BIN=/opt/ckb/0.202.0/ckb
FIBER_CKB_CLI_BIN=/opt/ckb/0.202.0/ckb-cli
# Optional prebuilt binaries copied into the sandbox. The sandbox patch falls
# back to a sandbox-local Cargo build when either variable is unset.
FIBER_FNN_BIN=/srv/fiber-public-demo/runtime/artifacts/fnn
FIBER_UDT_INIT_BIN=/srv/fiber-public-demo/runtime/artifacts/udt-init
FIBER_LOCAL_ASSET=xudt
FIBER_LOCAL_LOG_DIR=/srv/fiber-public-demo/runtime/fiber-local-network
REMOVE_OLD_STATE=y
BATTLECODE_DIR=/srv/fiber-public-demo/battlecode25-scaffold/java
BATTLECODE_JDK_HOME=/usr/lib/jvm/java-21-openjdk-amd64
JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
BATTLECODE_ENGINE_JAR=/srv/fiber-public-demo/runtime/artifacts/battlecode25-java-3.1.0.jar
BATTLECODE_ENGINE_VERSION=3.1.0
BATTLECODE_LEDGER_PATH=/srv/fiber-public-demo/runtime/battlecode-demo.sqlite
BATTLECODE_AWARD_SETTLEMENT=local-ledger
FIBER_PAID_HTTP_EVIDENCE_API_BASE=http://fiber-demo.avato.online
