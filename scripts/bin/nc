#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-z" && "$#" -eq 3 ]]; then
  host="$2"
  port="$3"
  echo "fiber-paid-http nc shim: timeout 2 bash -c :</dev/tcp/${host}/${port}" >&2
  timeout 2 bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1
  exit $?
fi

echo "fiber-paid-http nc shim only supports: nc -z HOST PORT" >&2
exit 2
