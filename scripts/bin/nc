#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "-z" && "$#" -eq 3 ]]; then
  host="$2"
  port="$3"
  if [[ -x /usr/bin/nc ]]; then
    exec /usr/bin/nc -z -w 2 "$host" "$port"
  fi
  if command -v timeout >/dev/null 2>&1; then
    timeout 2 bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1
    exit $?
  fi
  bash -c ":</dev/tcp/${host}/${port}" >/dev/null 2>&1
  exit $?
fi

echo "fiber-paid-http nc shim only supports: nc -z HOST PORT" >&2
exit 2
